# =============================================================================
# Kalshi Weather Trading Daemon — example environment file
# Copy to `.env` and fill in your credentials:   cp .env.example .env
#
# Only the variables listed here are read by the code. Each trading/risk knob
# overrides the same-named constant in kalshi/config.py — leave it commented to
# use the coded default shown. Out-of-range or non-numeric values are ignored
# with a warning. Comments belong on their own line above the value they
# describe (an inline `# comment` after a value is now stripped safely, but
# keeping them separate is clearer).
# =============================================================================

# ── Kalshi API credentials (required) ──
# Get these from https://kalshi.com/account/api-keys
KALSHI_API_KEY_ID=your_api_key_id_here
KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi_private.pem

# ── Telegram notifications (optional) ──
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Mode ──
# Paper mode (the default) places NO real orders. Set to false ONLY for live trading.
PAPER_TRADING=true

# ── Trading limits (optional; defaults shown) ──
# MAX_CONTRACTS=8
# MAX_COST_PER_TRADE=500
# MAX_OPEN_POSITIONS=20
# MAX_DAILY_TRADES=40
# MIN_VOLUME=10
# MAX_EDGE_CENTS=60
# MAX_SPREAD=30

# ── Mode-dependent knobs (optional) ──
# These have different built-in defaults for paper vs. live. An explicit value
# here overrides whichever mode would otherwise apply.
# MIN_EDGE_CENTS=10           # paper 10 / live 15
# MIN_CONFIDENCE_SCORE=0.5    # paper 0.5 / live 0.6 (range 0..1)
# MODEL_WEIGHT=0.3            # model blend weight in the log-odds blend (range 0..1)
# MAX_DISAGREEMENT_CENTS=40   # paper 40 / live 25
# MAX_FAIR_MARKET_RATIO=3.5   # paper 3.5 / live 3.0 (range >= 1.0)
# MIN_YES_PRICE=5             # paper 5 / live 15
# MIN_NO_PRICE=5              # paper 5 / live 15

# ── Risk limits (optional; defaults shown) ──
# MAX_DAILY_LOSS_CENTS=500    # daily stop-loss ($5.00)
# MAX_WEEKLY_LOSS_CENTS=1000  # weekly stop-loss ($10.00)
# MAX_PER_GROUP=2             # max positions per correlation group
# MAX_PER_CITY_DATE=1         # max positions per city per settlement date

# ── Paths (optional) ──
# WEATHER_ACCURACY_PATH=./weather_accuracy.json
